{
  "name": "@pushary/mastra",
  "version": "0.1.0",
  "description": "Human-in-the-loop for Mastra: a blocking createTool that asks a real human on their phone, plus a durable suspend/resume workflow step.",
  "author": "Pushary <business@pushary.com>",
  "homepage": "https://pushary.com/human-in-the-loop-mastra",
  "repository": {
    "type": "git",
    "url": "https://github.com/Pushary/pushary-mastra.git"
  },
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run build && npm run typecheck"
  },
  "dependencies": {
    "@pushary/server": "^1.3.2"
  },
  "peerDependencies": {
    "@mastra/core": "^1.0.0",
    "zod": "^3.25.0 || ^4.0.0"
  },
  "devDependencies": {
    "@mastra/core": "^1.0.0",
    "@types/node": "^20.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "vitest": "^2.1.0",
    "zod": "^3.25.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "pushary",
    "mastra",
    "createtool",
    "suspend-resume",
    "human-in-the-loop",
    "hitl",
    "agent",
    "approval",
    "workflow",
    "llm"
  ],
  "bugs": {
    "url": "https://github.com/Pushary/pushary-mastra/issues"
  }
}
